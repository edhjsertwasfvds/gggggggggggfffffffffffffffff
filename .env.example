# Steam API Key (для проверки VAC, игр, аккаунтов)
STEAM_API_KEY=your_steam_api_key_here

# FEAR Project API Token
FEAR_ACCESS_TOKEN=your_fear_access_token_here

# Faceit API Key (для отображения уровня Faceit)
FACEIT_API_KEY=your_faceit_api_key_here

# Cookie для авторизованного доступа к csstats.gg
# Пример: XSRF-TOKEN=...; laravel_session=...
CSSTATS_COOKIE=

# Cookie для проверки через dxdcs.ru (опционально; при отсутствии проверка отключена)
DXDCS_COOKIE=

# Cookie для проверки через top2.fun (опционально; при отсутствии проверка отключена)
TOP2_PHPSESSID=

# SteamID админа для счётчика «Наказания» (davidonchik.online; при отсутствии показывается 0)
# PUNISHMENTS_ADMIN_STEAM_ID=76561199872130492

# Server Configuration
PORT=3000
NODE_ENV=development

# Путь к SQLite (только если НЕ задан DATABASE_URL — иначе панель идёт в Postgres).
# Windows: C:/data/fear/fear-data.db (вне OneDrive)
# Railway без Postgres: Volume (RAILWAY_VOLUME_MOUNT_PATH) или явный путь.
# DATABASE_PATH=C:/data/fear/fear-data.db

# --- PostgreSQL: одна переменная для всего ---
# Та же БД, что у VibeCodingBdd (admins/profiles): поиск в «Проверка» + пользователи/сессии панели (таблицы panel_*).
# На Railway: DATABASE_URL=${{ Postgres.DATABASE_URL }}
# Перед первым запуском на новой БД примените в репозитории BDD файл db/panel.sql (см. папку VibeCodingBdd/db в этом проекте).
# DATABASE_URL=postgresql://USER:PASSWORD@HOSTNAME:PORT/railway
# При проблемах SSL: PG_SSL=1

# Секрет для GET /api/moderator/players (все игроки + баны + репорты). Bearer или ?token=
# MODERATOR_API_TOKEN=длинная_случайная_строка

# Опционально: общий секрет для сервисов (CI, бот) к GET /api/launcher/players. У каждого пользователя также есть личный ключ в БД (см. сайт «Для лаунчера», уровень 5).
# LAUNCHER_API_KEY=длинная_случайная_строка
# LAUNCHER_API_TOKEN=

# CORS (production only, optional)
# ALLOWED_ORIGIN=https://yourdomain.com

# Пользователи (формат: username:password:level через запятую)
# Создаются при первом запуске, если ещё не существуют
# Уровни 1-5 (5 = суперадмин, сброс пользователей, пригласительные коды)
DEFAULT_USERS=User1:securepass1:5,User2:securepass2:4

# Альтернатива DEFAULT_USERS: один основной логин из env
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change_me
# ADMIN_LEVEL=5
# ADMIN_DISPLAY_NAME=Administrator

# Опционально: ссылка "куда писать за доступом" на странице /auth
# AUTH_SUPPORT_URL=https://discord.com/users/your_id
# AUTH_SUPPORT_LABEL=Discord

# --- Discord OAuth2 (авторизация через Discord) ---
# Создай приложение на https://discord.com/developers/applications, получи Client ID и Client Secret.
# Redirect URI в Discord: https://yourdomain.com/api/auth/discord/callback
# Скоупы: identify + guilds.members.read
# DISCORD_CLIENT_ID=1234567890123456789
# DISCORD_CLIENT_SECRET=your_client_secret_here
# DISCORD_REDIRECT_URI=https://yourdomain.com/api/auth/discord/callback
# DISCORD_GUILD_ID=1234567890123456789
# DISCORD_BOT_TOKEN=Bot_token_for_fetching_roles (optional, нужен для guilds.members.read)
# Уровни ролей Discord: role_id:level, role_id:level, ... (level 1-5, 0 = нет доступа)
# Пример: DISCORD_ROLE_LEVELS=1234567890123456789:5,9876543210987654321:3
# DISCORD_ROLE_LEVELS=
# DISCORD_DEFAULT_LEVEL=0
# Discord ID пользователей, которым всегда выдавать level 5 (владельцы, независимо от ролей)
# DISCORD_FORCE_LEVEL_5_IDS=1500235583367417866,789091572297760798

